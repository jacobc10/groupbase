{
  "manifest_version": 3,
  "name": "GroupBase",
  "version": "1.1.0",
  "description": "Turn your Facebook Group into a CRM. Capture member data automatically when you approve requests.",
  "permissions": [
    "activeTab",
    "storage",
    "tabs"
  ],
  "host_permissions": [
    "https://www.facebook.com/*",
    "https://bpbombdtzrthhbqoxlao.supabase.co/*"
  ],
  "content_scripts": [
    {
      "matches": [
        "https://www.facebook.com/groups/*"
      ],
      "js": [
        "content/facebook-content.js"
      ],
      "css": [
        "content/content-styles.css"
      ],
      "run_at": "document_idle"
    }
  ],
  "background": {
    "service_worker": "background/service-worker.js"
  },
  "action": {
    "default_popup": "popup/popup.html",
    "default_title": "GroupBase"
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "web_accessible_resources": [
    {
      "resources": [
        "content/content-styles.css"
      ],
      "matches": [
        "https://www.facebook.com/*"
      ]
    }
  ]
}
